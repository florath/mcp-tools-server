{
    "server": {
        "host": "127.0.0.1",
        "port": 7091,
        "debug": false
    },
    "security": {
        "max_file_size_mb": 100,
        "allowed_file_extensions": [
            ".json",
            ".yaml",
            ".yml",
            ".txt",
            ".py",
            ".js",
            ".ts",
            ".md",
            ".csv",
            ".xml",
            ".html",
            ".css",
            ".sql",
            ".toml",
            ".cfg",
            ".ini",
            ".conf",
            ".sh",
            ".bat",
            ".dockerfile",
            ".dockerignore",
            ".gitignore",
            ".env",
            ".lock",
            ".rs",
            ".log",
            ".toml"
        ]
    },
    "sessions": {
        "timeout_seconds": 3600,
        "max_sessions": 100
    },
    "logging": {
        "level": "INFO",
        "format": "json"
    },
    "tools": {
        "read_file": {
            "enabled": true,
            "max_files_per_request": 10
        },
        "write_file": {
            "enabled": true
        },
        "remove_file": {
            "enabled": true
        },
        "move_file": {
            "enabled": true
        },
        "edit_file": {
            "enabled": true
        },
        "find_files": {
            "enabled": true
        },
        "search_content": {
            "enabled": true
        },
        "list_dir": {
            "enabled": true
        },
        "mkdir": {
            "enabled": true
        },
        "rmdir": {
            "enabled": true
        },
        "dir_exists": {
            "enabled": true
        }
    }
}